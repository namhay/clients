generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(STAFF)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id         String    @id @default(cuid())
  name       String
  email      String
  phone      String?
  company    String?
  address    String?
  vatTin     String?
  telegramId String?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  services   Service[]
  invoices   Invoice[]
}

model ProductType {
  id              String           @id @default(cuid())
  name            String           @unique
  slug            String           @unique
  color           String           @default("blue")
  hasHostingSpecs Boolean          @default(false)
  active          Boolean          @default(true)
  sortOrder       Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  packages        ProductPackage[]
  services        Service[]
}

model ProductPackage {
  id              String      @id @default(cuid())
  productTypeId   String
  productType     ProductType @relation(fields: [productTypeId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  diskSpaceGb     Int?
  bandwidthGb     Int?
  emailAccounts   Int?
  databases       Int?
  addonDomains    Int?
  priceMonthly    Float       @default(0)
  priceQuarterly  Float       @default(0)
  priceSemiAnnual Float       @default(0)
  priceYearly     Float       @default(0)
  setupFee        Float       @default(0)
  active          Boolean     @default(true)
  sortOrder       Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  services        Service[]

  @@unique([productTypeId, name])
}

model Service {
  id               String          @id @default(cuid())
  clientId         String
  client           Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  productTypeId    String
  productType      ProductType     @relation(fields: [productTypeId], references: [id], onDelete: Restrict)
  productPackageId String?
  productPackage   ProductPackage? @relation(fields: [productPackageId], references: [id], onDelete: SetNull)
  name             String
  startDate        DateTime
  expiryDate       DateTime
  nextDueDate      DateTime?
  price            Float
  setupFee         Float           @default(0)
  recurring        Boolean         @default(false)
  period           Period?
  status           Status          @default(ACTIVE)
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model Invoice {
  id        String        @id @default(cuid())
  clientId  String
  client    Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoiceNo String        @unique
  items     InvoiceItem[]
  subtotal  Float
  tax       Float         @default(0)
  total     Float
  status    InvoiceStatus @default(UNPAID)
  dueDate   DateTime
  paidAt    DateTime?
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model InvoiceItem {
  id          String    @id @default(cuid())
  invoiceId   String
  invoice     Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Int       @default(1)
  unitPrice   Float
  total       Float
  periodStart DateTime?
  periodEnd   DateTime?
}

model AppSettings {
  id                    String   @id @default("default")
  companyName           String   @default("Your Company Ltd.")
  companyAddress        String   @default("")
  companyEmail          String   @default("")
  companyPhone          String   @default("")
  invoicePrefix         String   @default("INV-")
  reminderDays          Int      @default(7)
  smtpHost              String   @default("")
  smtpPort              Int      @default(465)
  smtpSecure            Boolean  @default(true)
  smtpUser              String   @default("")
  smtpPass              String   @default("")
  smtpFrom              String   @default("")
  telegramBotToken      String   @default("")
  telegramDefaultChatId String   @default("")
  updatedAt             DateTime @updatedAt
}

model ReminderLog {
  id        String   @id @default(cuid())
  clientId  String
  type      String
  channel   String
  message   String?
  status    String   @default("sent")
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  STAFF
}

enum Period {
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  YEARLY
}

enum Status {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum InvoiceStatus {
  UNPAID
  PAID
  OVERDUE
  CANCELLED
}
