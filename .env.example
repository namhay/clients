# Database (Neon PostgreSQL — remote, used for local dev and Vercel production)
# Neon dashboard → Connection details → "Pooled connection" (host ends with -pooler)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="generate-a-random-secret-here-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# cPanel SMTP Email
SMTP_HOST="mail.yourdomain.com"
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER="noreply@yourdomain.com"
SMTP_PASS="your-email-password"
SMTP_FROM="ClientDesk <noreply@yourdomain.com>"

# Telegram Bot
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_BOT_USERNAME="your_bot_username"
TELEGRAM_WEBHOOK_SECRET=""
TELEGRAM_DEFAULT_CHAT_ID=""

# App
NEXT_PUBLIC_APP_NAME="ClientDesk"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
COMPANY_NAME="Your Company Ltd."
COMPANY_ADDRESS="Phnom Penh, Cambodia"
COMPANY_EMAIL="info@yourdomain.com"
COMPANY_PHONE="+855 12 345 678"
INVOICE_PREFIX="INV-"
INVOICE_START_NUMBER="1"

# Cron (automated reminder alerts — required for /api/cron/reminders)
CRON_SECRET="generate-a-random-secret-for-cron"
